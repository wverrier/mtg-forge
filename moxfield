<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>FORGE // MOXFIELD UPLINK</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --gunmetal: #111c1e; --dark: #1a2527; --cyan: #4dd9f0; }
        body { background: var(--gunmetal); color: #e8eef0; font-family: 'Rajdhani', sans-serif; min-height: 100vh; }
        .panel { background: var(--dark); border: 1px solid rgba(77,217,240,0.1); }
        textarea { background: rgba(0,0,0,0.3) !important; border: 1px solid rgba(77,217,240,0.2) !important; color: #4dd9f0 !important; font-family: monospace; }
        .btn-primary { background: transparent; border: 1px solid var(--cyan); color: var(--cyan); font-family: 'Bebas Neue'; transition: 0.2s; }
        .btn-primary:hover { background: var(--cyan); color: var(--gunmetal); box-shadow: 0 0 15px var(--cyan); }
    </style>
</head>
<body x-data="moxfieldTranslator()">

    <div class="max-w-4xl mx-auto py-12 px-6">
        <header class="mb-12 border-b border-cyan-400/20 pb-6">
            <h1 class="text-5xl font-bold text-cyan-400 italic" style="font-family: 'Bebas Neue'">MOXFIELD // COLLECTION UPLINK</h1>
            <p class="text-slate-400 text-sm tracking-widest uppercase">Format: [Count] [Name] [[Set]] [Collector Number]</p>
        </header>

        <div class="grid gap-8">
            <div class="panel p-6">
                <label class="block text-xs font-bold text-cyan-400 mb-2 uppercase tracking-tighter">Raw Data Input</label>
                <textarea x-model="rawInput" rows="8" class="w-full p-4 rounded focus:outline-none focus:border-cyan-400" placeholder="1 Superior Foes of Spider-Man [SPM] 96"></textarea>
            </div>

            <div class="flex justify-center">
                <button @click="processData()" class="btn-primary px-12 py-3 text-xl uppercase italic">Process for CSV</button>
            </div>

            <div class="panel p-6" x-show="csvOutput">
                <div class="flex justify-between items-center mb-2">
                    <label class="text-xs font-bold text-cyan-400 uppercase tracking-tighter">CSV Output (Moxfield Format)</label>
                    <button @click="downloadCSV()" class="text-[10px] text-white bg-white/10 px-2 py-1 hover:bg-cyan-400 hover:text-black">Download .CSV</button>
                </div>
                <textarea x-model="csvOutput" readonly rows="8" class="w-full p-4 rounded opacity-80 text-sm"></textarea>
            </div>
        </div>

        <footer class="mt-12 opacity-20 font-mono text-[10px] text-center tracking-[0.5em] uppercase">
            Data Scrubbing Active // CSV-RFC4180 Compliant
        </footer>
    </div>

    <script>
        function moxfieldTranslator() {
            return {
                rawInput: '',
                csvOutput: '',
                
                processData() {
                    const lines = this.rawInput.split('\n');
                    let csvRows = ['Count,Name,Edition,Condition,Language,Foil,Collector Number'];
                    
                    lines.forEach(line => {
                        if (!line.trim()) return;

                        // Regex logic:
                        // ^(\d+) -> Matches count
                        // (.*?)  -> Matches name (lazy)
                        // \[ (.*?) \] -> Matches set inside brackets
                        // \s* (\d*) -> Matches collector number at end
                        const regex = /^(\d+)\s+(.*?)\s+\[(.*?)\]\s*(.*)$/;
                        const match = line.match(regex);

                        if (match) {
                            const [full, count, name, set, collectorNum] = match;
                            // Clean commas from names to prevent CSV breakage
                            const cleanName = `"${name.trim()}"`;
                            const cleanSet = set.trim();
                            const cleanNum = collectorNum.trim();
                            
                            // Defaulting to Near Mint, English, and non-foil
                            csvRows.push(`${count},${cleanName},${cleanSet},Near Mint,English,,${cleanNum}`);
                        }
                    });

                    this.csvOutput = csvRows.join('\n');
                },

                downloadCSV() {
                    const blob = new Blob([this.csvOutput], { type: 'text/csv' });
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.setAttribute('hidden', '');
                    a.setAttribute('href', url);
                    a.setAttribute('download', 'moxfield_import.csv');
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                }
            }
        }
    </script>
</body>
</html>
